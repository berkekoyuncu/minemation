<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Minemation.Mobile.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Minemation.Mobile"
    xmlns:views="clr-namespace:Minemation.Mobile.Views"
    Title="Minemation"
    Shell.BackgroundColor="{DynamicResource Black}"
    Shell.TabBarBackgroundColor="{DynamicResource MidnightBlue}"
    Shell.TabBarUnselectedColor="{DynamicResource Gray400}"
    Shell.TabBarTitleColor="{DynamicResource Primary}">

    <TabBar>
        <Tab Title="Personel">
            <ShellContent ContentTemplate="{DataTemplate views:PersonnelPage}" />
        </Tab>
        <Tab Title="Vardiya">
            <ShellContent ContentTemplate="{DataTemplate local:MainPage}" />
        </Tab>
        <Tab Title="Ekipman">
            <ShellContent ContentTemplate="{DataTemplate local:MainPage}" />
        </Tab>
        <Tab Title="Profil">
            <ShellContent ContentTemplate="{DataTemplate local:MainPage}" />
        </Tab>
    </TabBar>

</Shell>
