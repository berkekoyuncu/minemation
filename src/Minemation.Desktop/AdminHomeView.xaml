<UserControl x:Class="Minemation.Desktop.AdminHomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="Transparent">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="YÖNETİCİ ANA EKRANI"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryBrush}" />

                <TextBlock x:Name="LastUpdatedText"
                           Text="Son güncelleme: -"
                           FontSize="13"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="0,5,0,0" />
            </StackPanel>

            <Button Grid.Column="1"
                    Style="{StaticResource MaterialDesignPaperButton}"
                    Background="{DynamicResource PrimaryBrush}"
                    Foreground="White"
                    Padding="15,0"
                    Height="40"
                    Click="BtnRefresh_Click">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Refresh"
                                             Margin="0,0,5,0"
                                             VerticalAlignment="Center"/>
                    <TextBlock Text="Yenile" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </Grid>

        <!-- Özet Kartları -->
        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="18" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="Toplam Personel" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" />
                    <TextBlock x:Name="PersonnelCountText" Text="0" Foreground="{DynamicResource PrimaryBrush}" FontSize="28" FontWeight="Bold" Margin="0,6,0,0" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="18" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="Aktif Vardiya" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" />
                    <TextBlock x:Name="ActiveShiftCountText" Text="0" Foreground="{DynamicResource PrimaryBrush}" FontSize="28" FontWeight="Bold" Margin="0,6,0,0" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="18" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="Açık Vaka" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" />
                    <TextBlock x:Name="OpenIncidentCountText" Text="0" Foreground="{DynamicResource ErrorBrush}" FontSize="28" FontWeight="Bold" Margin="0,6,0,0" />
                </StackPanel>
            </Border>

            <Border Grid.Column="3" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="18">
                <StackPanel>
                    <TextBlock Text="Eşik Dışı Sensör" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" />
                    <TextBlock x:Name="RiskSensorCountText" Text="0" Foreground="{DynamicResource ErrorBrush}" FontSize="28" FontWeight="Bold" Margin="0,6,0,0" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- Ana İçerik -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Sistem Özeti -->
            <Border Grid.Column="0"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Margin="0,0,15,0">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="45" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{DynamicResource CardBrush}"
                            CornerRadius="8,8,0,0"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,0,0,1">
                        <TextBlock Text="Sistem Özeti"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"
                                   Margin="15,0" />
                    </Border>

                    <StackPanel Grid.Row="1" Margin="15">
                        <TextBlock Text="Personel Durumu" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" />
                        <TextBlock x:Name="PersonnelSummaryText" Text="-" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="15" FontWeight="SemiBold" Margin="0,4,0,14" />

                        <TextBlock Text="Ekipman Durumu" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" />
                        <TextBlock x:Name="EquipmentSummaryText" Text="-" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="15" FontWeight="SemiBold" Margin="0,4,0,14" />

                        <TextBlock Text="Vardiya Durumu" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" />
                        <TextBlock x:Name="ShiftSummaryText" Text="-" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="15" FontWeight="SemiBold" Margin="0,4,0,14" />

                        <TextBlock Text="Risk Durumu" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" />
                        <Border Background="{DynamicResource InfoBrush}" CornerRadius="10" Padding="8,3" HorizontalAlignment="Left" Margin="0,5,0,0">
                            <TextBlock x:Name="RiskStatusText" Text="-" Foreground="White" FontSize="12" FontWeight="Bold" />
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Sağ Alan -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Harita Placeholder -->
                <Border Grid.Row="0"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Margin="0,0,0,15">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="45" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="{DynamicResource CardBrush}"
                                CornerRadius="8,8,0,0"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,0,0,1">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0">
                                <materialDesign:PackIcon Kind="MapMarkerRadius"
                                                         Width="22"
                                                         Height="22"
                                                         Foreground="{DynamicResource PrimaryBrush}"
                                                         Margin="0,0,8,0" />
                                <TextBlock Text="Harita"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                            </StackPanel>
                        </Border>

                        <Grid Grid.Row="1">
                            <Viewbox Stretch="UniformToFill"
             ClipToBounds="True">
                                <Grid Width="1000"
              Height="650">

                                    <Image Source="Resources/Images/MineMap.png"
                   Width="1000"
                   Height="650"
                   Stretch="Fill"
                   Opacity="1" />

                                    <Rectangle Fill="#22000000"
                       Width="1000"
                       Height="650" />

                                    <Canvas Width="1000"
                    Height="650">

                                        <!-- Ana giriş -->
                                        <StackPanel Canvas.Left="115"
                            Canvas.Top="135"
                            Margin="-18,-38,0,0">
                                            <materialDesign:PackIcon Kind="Gate"
                                             Width="36"
                                             Height="36"
                                             Foreground="{DynamicResource TextSecondaryBrush}"
                                             HorizontalAlignment="Center" />
                                            <Border Background="{DynamicResource CardBrush}"
                            CornerRadius="4"
                            Padding="5,1"
                            Margin="0,-6,0,0">
                                                <TextBlock Text="Ana Giriş"
                                   FontSize="10"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                                            </Border>
                                        </StackPanel>

                                        <!-- Ekipman -->
                                        <StackPanel Canvas.Left="410"
                            Canvas.Top="285"
                            Margin="-15,-34,0,0">
                                            <materialDesign:PackIcon Kind="Excavator"
                                             Width="32"
                                             Height="32"
                                             Foreground="{DynamicResource PrimaryBrush}"
                                             HorizontalAlignment="Center" />
                                            <Border Background="{DynamicResource CardBrush}"
                            CornerRadius="4"
                            Padding="5,1"
                            Margin="0,-5,0,0">
                                                <TextBlock Text="Ekipman"
                                   FontSize="10"
                                   Foreground="{DynamicResource PrimaryBrush}"
                                   FontWeight="Bold" />
                                            </Border>
                                        </StackPanel>

                                        <!-- Personel / görev noktası -->
                                        <StackPanel Canvas.Left="500"
                            Canvas.Top="325"
                            Margin="-15,-36,0,0">
                                            <materialDesign:PackIcon Kind="AccountHardHat"
                                             Width="32"
                                             Height="32"
                                             Foreground="{DynamicResource SuccessBrush}"
                                             HorizontalAlignment="Center" />
                                            <Border Background="{DynamicResource CardBrush}"
                            CornerRadius="4"
                            Padding="5,1"
                            Margin="0,-5,0,0">
                                                <TextBlock Text="Görev Yeri"
                                   FontSize="10"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontWeight="SemiBold" />
                                            </Border>
                                        </StackPanel>

                                        <!-- Riskli bölge -->
                                        <StackPanel Canvas.Left="530"
                            Canvas.Top="430"
                            Margin="-16,-36,0,0">
                                            <materialDesign:PackIcon Kind="Alert"
                                             Width="34"
                                             Height="34"
                                             Foreground="{DynamicResource WarningBrush}"
                                             HorizontalAlignment="Center" />
                                            <Border Background="{DynamicResource CardBrush}"
                            CornerRadius="4"
                            Padding="5,1"
                            Margin="0,-5,0,0">
                                                <TextBlock Text="Riskli Bölge"
                                   FontSize="10"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                                            </Border>
                                        </StackPanel>
                                    </Canvas>
                                </Grid>
                            </Viewbox>

                            <Rectangle Fill="#22000000" />

                            <Button Content="Haritayı Aç"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Margin="0,0,18,18"
            Padding="16,6"
            Background="{DynamicResource PrimaryBrush}"
            Foreground="White"
            Click="OpenMapButton_Click" />
                        </Grid>
                    </Grid>
                </Border>

                <!-- Son Vakalar -->
                <Border Grid.Row="1"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="45" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="{DynamicResource CardBrush}"
                                CornerRadius="8,8,0,0"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,0,0,1">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0">
                                <materialDesign:PackIcon Kind="AlertCircle"
                                                         Width="22"
                                                         Height="22"
                                                         Foreground="{DynamicResource ErrorBrush}"
                                                         Margin="0,0,8,0" />
                                <TextBlock Text="Son Vakalar"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                            </StackPanel>
                        </Border>

                        <DataGrid Grid.Row="1"
                                  x:Name="RecentIncidentsGrid"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  Background="{DynamicResource SurfaceBrush}"
                                  RowBackground="{DynamicResource SurfaceBrush}"
                                  AlternatingRowBackground="{DynamicResource CardBrush}"
                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                  BorderThickness="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Vaka" Width="*" Binding="{Binding VakaAdi}" />
                                <DataGridTextColumn Header="Tür" Width="120" Binding="{Binding VakaTuru}" />
                                <DataGridTextColumn Header="Ciddiyet" Width="110" Binding="{Binding VakaCiddiyetSeviyesi}" />
                                <DataGridTextColumn Header="Durum" Width="100" Binding="{Binding VakaDurumu}" />
                                <DataGridTextColumn Header="Tarih" Width="140" Binding="{Binding TarihText}" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>