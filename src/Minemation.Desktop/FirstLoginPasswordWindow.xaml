<Window x:Class="Minemation.Desktop.FirstLoginPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="İlk Giriş - Şifre Oluştur"
        Width="520"
        Height="460"
        MinWidth="520"
        MinHeight="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BackgroundBrush}"
        TextElement.Foreground="{DynamicResource TextPrimaryBrush}"
        FontFamily="{DynamicResource MaterialDesignFont}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="İlk Giriş Şifre Oluşturma"
                       FontSize="23"
                       FontWeight="Bold"
                       Foreground="{DynamicResource PrimaryBrush}" />

            <TextBlock Text="Sisteme devam edebilmek için ilk şifrenizi oluşturmanız gerekiyor."
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,8,0,0" />
        </StackPanel>

        <StackPanel Grid.Row="1">
            <TextBox x:Name="TcknBox"
                     materialDesign:HintAssist.Hint="T.C. Kimlik No"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     MaxLength="11"
                     Margin="0,0,0,12"
                     Foreground="{DynamicResource TextPrimaryBrush}" />

            <PasswordBox x:Name="NewPasswordBox"
                         materialDesign:HintAssist.Hint="Yeni Şifre"
                         Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                         Margin="0,0,0,12"
                         Foreground="{DynamicResource TextPrimaryBrush}" />

            <PasswordBox x:Name="NewPasswordAgainBox"
                         materialDesign:HintAssist.Hint="Yeni Şifre Tekrar"
                         Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                         Margin="0,0,0,12"
                         Foreground="{DynamicResource TextPrimaryBrush}" />

            <TextBlock x:Name="ErrorText"
                       Visibility="Collapsed"
                       Foreground="{DynamicResource ErrorBrush}"
                       TextWrapping="Wrap"
                       Margin="0,5,0,0" />
        </StackPanel>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">

            <Button Content="İptal"
                    Width="95"
                    Margin="0,0,10,0"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Click="CancelButton_Click" />

            <Button x:Name="CreatePasswordButton"
                    Content="Şifre Oluştur"
                    Width="135"
                    Background="{DynamicResource PrimaryBrush}"
                    Foreground="White"
                    Click="CreatePasswordButton_Click" />
        </StackPanel>
    </Grid>
</Window>