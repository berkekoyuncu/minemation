<Window x:Class="Minemation.Desktop.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Minemation - Giriş" Height="720" Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}"
        FontFamily="{DynamicResource MaterialDesignFont}"
        TextElement.Foreground="{DynamicResource TextPrimaryBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5*" />
            <ColumnDefinition Width="5*" />
        </Grid.ColumnDefinitions>

        <!-- Left Side: Image / Motto -->
        <Border Grid.Column="0" Background="{DynamicResource SurfaceBrush}">
            <!-- Background Image -->
            <Grid>
                <Image Source="/Resources/photo1.jpeg" Stretch="UniformToFill" />
                <!-- Overlay -->
                <Border Background="#800F172A" />
                
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <materialDesign:PackIcon Kind="HardHat" Width="120" Height="120" Foreground="{DynamicResource PrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                    <TextBlock Text="MINEMATION" FontSize="48" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" />
                    <TextBlock Text="Güvenli ve Verimli Maden Sahası Yönetimi" FontSize="20" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,10,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Right Side: Login Form -->
        <Grid Grid.Column="1" Background="{DynamicResource BackgroundBrush}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Stretch" Margin="100,0,100,0">
                <TextBlock Text="Sisteme Giriş" FontSize="36" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,0,10" />
                <TextBlock Text="Giriş yapmak için lütfen kullanıcı bilgilerinizi giriniz." FontSize="16" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,40" TextWrapping="Wrap" />

                <!-- T.C. Kimlik -->
                <TextBox x:Name="IdentityBox" 
                         materialDesign:HintAssist.Hint="T.C. Kimlik Numarası"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         BorderBrush="{DynamicResource BorderBrush}"
                         FontSize="16" Height="50" Margin="0,0,0,20" />

                <!-- Şifre -->
                <PasswordBox x:Name="PasswordBox" 
                             materialDesign:HintAssist.Hint="Şifre"
                             Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"
                             FontSize="16" Height="50" Margin="0,0,0,30" />

                <!-- Giriş Butonu -->
                <Button x:Name="LoginButton"
                        Content="Giriş Yap"
                        Style="{StaticResource MaterialDesignPaperButton}"
                        Background="{DynamicResource PrimaryBrush}"
                        Foreground="White"
                        Height="50" FontSize="18"
                        Click="LoginButton_Click" />
                
                <TextBlock x:Name="ErrorText" Text="" Foreground="{DynamicResource ErrorBrush}" Margin="0,10,0,0" HorizontalAlignment="Center" Visibility="Collapsed" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>