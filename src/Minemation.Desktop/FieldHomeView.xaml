<UserControl x:Class="Minemation.Desktop.FieldHomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="Transparent">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="SAHA PERSONELİ ANA EKRANI"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryBrush}" />

                <TextBlock x:Name="LastUpdatedText"
                           Text="Son güncelleme: -"
                           FontSize="13"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="0,5,0,0" />
            </StackPanel>

            <Button Grid.Column="1"
                    Style="{StaticResource MaterialDesignPaperButton}"
                    Background="{DynamicResource PrimaryBrush}"
                    Foreground="White"
                    Padding="15,0"
                    Height="40"
                    Click="BtnRefresh_Click">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Refresh"
                                             Margin="0,0,5,0"
                                             VerticalAlignment="Center"/>
                    <TextBlock Text="Yenile" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Aktif Vardiya Bilgileri -->
            <Border Grid.Column="0"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Margin="0,0,15,0">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="45" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{DynamicResource CardBrush}"
                            CornerRadius="8,8,0,0"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,0,0,1">
                        <TextBlock Text="Aktif Vardiya Bilgileri"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"
                                   Margin="15,0" />
                    </Border>

                    <StackPanel Grid.Row="1" Margin="15">
                        <TextBlock Text="Tarih"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="13" />
                        <TextBlock x:Name="ShiftDateText"
                                   Text="-"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Margin="0,3,0,12" />

                        <TextBlock Text="Saat"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="13" />
                        <TextBlock x:Name="ShiftTimeText"
                                   Text="-"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Margin="0,3,0,12" />

                        <TextBlock Text="Ekipman"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="13" />
                        <TextBlock x:Name="EquipmentText"
                                   Text="-"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Margin="0,3,0,12" />

                        <TextBlock Text="Konum"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="13" />
                        <TextBlock x:Name="LocationText"
                                   Text="-"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Margin="0,3,0,12" />

                        <TextBlock Text="Durum"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="13" />
                        <Border Background="{DynamicResource InfoBrush}"
                                CornerRadius="10"
                                Padding="8,3"
                                HorizontalAlignment="Left"
                                Margin="0,5,0,0">
                            <TextBlock x:Name="ShiftStatusText"
                                       Text="-"
                                       Foreground="White"
                                       FontSize="12"
                                       FontWeight="Bold" />
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Sağ Alan -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Harita Placeholder -->
                <Border Grid.Row="0"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Margin="0,0,0,15">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="45" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="{DynamicResource CardBrush}"
                                CornerRadius="8,8,0,0"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,0,0,1">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0">
                                <materialDesign:PackIcon Kind="MapMarkerRadius"
                                                         Width="22"
                                                         Height="22"
                                                         Foreground="{DynamicResource PrimaryBrush}"
                                                         Margin="0,0,8,0" />
                                <TextBlock Text="Harita"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                            </StackPanel>
                        </Border>

                        <Grid Grid.Row="1">
                            <Border Width="260"
                                    Height="150"
                                    Background="{DynamicResource CardBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Top"
                                    Margin="20">
                                <StackPanel HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                    <materialDesign:PackIcon Kind="Map"
                                                             Width="42"
                                                             Height="42"
                                                             Foreground="{DynamicResource TextSecondaryBrush}"
                                                             HorizontalAlignment="Center"
                                                             Margin="0,0,0,8" />
                                    <TextBlock Text="Harita modülü burada gösterilecek"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               TextAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Vakalarım -->
                <Border Grid.Row="1"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="45" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="{DynamicResource CardBrush}"
                                CornerRadius="8,8,0,0"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,0,0,1">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0">
                                <materialDesign:PackIcon Kind="AlertCircle"
                                                         Width="22"
                                                         Height="22"
                                                         Foreground="{DynamicResource ErrorBrush}"
                                                         Margin="0,0,8,0" />
                                <TextBlock Text="Vakalarım"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                            </StackPanel>
                        </Border>

                        <DataGrid Grid.Row="1"
                                  x:Name="MyIncidentsGrid"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  Background="{DynamicResource SurfaceBrush}"
                                  RowBackground="{DynamicResource SurfaceBrush}"
                                  AlternatingRowBackground="{DynamicResource CardBrush}"
                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                  BorderThickness="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Vaka" Width="*" Binding="{Binding VakaAdi}" />
                                <DataGridTextColumn Header="Tür" Width="120" Binding="{Binding VakaTuru}" />
                                <DataGridTextColumn Header="Ciddiyet" Width="110" Binding="{Binding VakaCiddiyetSeviyesi}" />
                                <DataGridTextColumn Header="Durum" Width="100" Binding="{Binding VakaDurumu}" />
                                <DataGridTextColumn Header="Tarih" Width="140" Binding="{Binding TarihText}" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>