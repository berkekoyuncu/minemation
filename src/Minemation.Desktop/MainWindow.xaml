<Window x:Class="Minemation.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Minemation - Ana Ekran" Height="768" Width="1366"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}"
        FontFamily="{DynamicResource MaterialDesignFont}"
        TextElement.Foreground="{DynamicResource TextPrimaryBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="70" /> <!-- Top Navigation Bar -->
            <RowDefinition Height="*" />  <!-- Main Content Area -->
        </Grid.RowDefinitions>

        <!-- Top Navigation Bar -->
        <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Logo -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,30,0">
                    <materialDesign:PackIcon Kind="HardHat" Width="36" Height="36" Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="MINEMATION" FontSize="22" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Navigation Tabs -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,0,0,0">
                    <Button x:Name="NavHome" Style="{StaticResource MaterialDesignFlatButton}" Foreground="{DynamicResource TextSecondaryBrush}" Height="50" Margin="0,0,5,0">
                        <materialDesign:PackIcon Kind="Home" Width="24" Height="24" />
                    </Button>
                    <Button x:Name="NavPersonnel" Content="Personel" Style="{StaticResource MaterialDesignFlatButton}" Foreground="{DynamicResource PrimaryBrush}" BorderBrush="{DynamicResource PrimaryBrush}" BorderThickness="0,0,0,3" Height="50" Margin="0,0,5,0" Click="NavPersonnel_Click" />
                    <Button x:Name="NavShift" Content="Vardiya" Style="{StaticResource MaterialDesignFlatButton}" Foreground="{DynamicResource TextSecondaryBrush}" Height="50" Margin="0,0,5,0" Click="NavShift_Click" />
                    <Button x:Name="NavEquipment" Content="Ekipman" Style="{StaticResource MaterialDesignFlatButton}" Foreground="{DynamicResource TextSecondaryBrush}" Height="50" Margin="0,0,5,0" />
                    <Button x:Name="NavIncidents" Content="Vakalar" Style="{StaticResource MaterialDesignFlatButton}" Foreground="{DynamicResource TextSecondaryBrush}" Height="50" Margin="0,0,5,0" />
                    <Button x:Name="NavReports" Content="Raporlar" Style="{StaticResource MaterialDesignFlatButton}" Foreground="{DynamicResource TextSecondaryBrush}" Height="50" Margin="0,0,5,0" />
                    <Button x:Name="NavRisk" Content="Risk İzleme" Style="{StaticResource MaterialDesignFlatButton}" Foreground="{DynamicResource TextSecondaryBrush}" Height="50" Margin="0,0,5,0" />
                    <Button x:Name="NavMap" Content="Harita" Style="{StaticResource MaterialDesignFlatButton}" Foreground="{DynamicResource TextSecondaryBrush}" Height="50" Margin="0,0,5,0" />
                </StackPanel>

                <!-- User Profile -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                    <Button x:Name="ThemeToggleButton" Style="{StaticResource MaterialDesignIconForegroundButton}" Click="ThemeToggleButton_Click" ToolTip="Temayı Değiştir" Margin="0,0,15,0" Foreground="{DynamicResource TextSecondaryBrush}">
                        <materialDesign:PackIcon x:Name="ThemeIcon" Kind="WeatherSunny" Width="24" Height="24" />
                    </Button>
                    <TextBlock x:Name="UserNameText" Text="Ahmet Yılmaz" FontSize="16" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <materialDesign:PackIcon Kind="AccountCircle" Width="40" Height="40" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <ContentControl x:Name="MainContent" Grid.Row="1" Margin="20" />
    </Grid>
</Window>
