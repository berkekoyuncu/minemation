<Window x:Class="Minemation.Desktop.CreateReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Rapor Oluştur"
        Width="620"
        Height="620"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        TextElement.Foreground="{DynamicResource TextPrimaryBrush}"
        FontFamily="{DynamicResource MaterialDesignFont}">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Template Üzerinden Rapor Oluştur"
                   FontSize="24"
                   FontWeight="Bold"
                   Foreground="{DynamicResource PrimaryBrush}"
                   Margin="0,0,0,20" />

        <StackPanel Grid.Row="1">
            <ComboBox x:Name="ReportTemplateComboBox"
                      materialDesign:HintAssist.Hint="Rapor Template"
                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                      Margin="0,0,0,12"
                      SelectionChanged="ReportTemplateComboBox_SelectionChanged">
                <ComboBoxItem Content="Günlük Ekipman Raporu" />
                <ComboBoxItem Content="Günlük Arıza Raporu" />
                <ComboBoxItem Content="Günlük Vaka Raporu" />
                <ComboBoxItem Content="Personel Çalışma Raporu" />
                <ComboBoxItem Content="Risk İzleme Raporu" />
            </ComboBox>

            <TextBox x:Name="ReportNameBox"
                     materialDesign:HintAssist.Hint="Rapor Adı"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     Margin="0,0,0,12" />

            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <DatePicker x:Name="StartDatePicker"
                            Grid.Column="0"
                            materialDesign:HintAssist.Hint="Başlangıç Tarihi"
                            Style="{StaticResource MaterialDesignOutlinedDatePicker}" />

                <DatePicker x:Name="EndDatePicker"
                            Grid.Column="2"
                            materialDesign:HintAssist.Hint="Bitiş Tarihi"
                            Style="{StaticResource MaterialDesignOutlinedDatePicker}" />
            </Grid>

            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBox x:Name="PersonnelIdBox"
                         Grid.Column="0"
                         materialDesign:HintAssist.Hint="Personel ID opsiyonel"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}" />

                <TextBox x:Name="EquipmentIdBox"
                         Grid.Column="2"
                         materialDesign:HintAssist.Hint="Ekipman ID opsiyonel"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}" />
            </Grid>

            <TextBox x:Name="ReportDescriptionBox"
                     materialDesign:HintAssist.Hint="Rapor Açıklaması / Template İçeriği"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     Height="210"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     VerticalContentAlignment="Top" />
        </StackPanel>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">

            <Button Content="İptal"
                    Width="100"
                    Margin="0,0,10,0"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Click="CancelButton_Click" />

            <Button Content="Oluştur"
                    Width="120"
                    Background="{DynamicResource PrimaryBrush}"
                    Foreground="White"
                    Click="CreateButton_Click" />
        </StackPanel>
    </Grid>
</Window>