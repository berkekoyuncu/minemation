<UserControl x:Class="Minemation.Desktop.HealthView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="Transparent">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="SAĞLIK BİLGİLERİM"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryBrush}" />

                <TextBlock x:Name="SubtitleText"
                           Text="Kişisel sağlık durumunuz, çalışma kısıtlarınız ve acil durum notlarınız"
                           FontSize="13"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="0,5,0,0" />
            </StackPanel>

            <Button Grid.Column="1"
                    Style="{StaticResource MaterialDesignPaperButton}"
                    Background="{DynamicResource PrimaryBrush}"
                    Foreground="White"
                    Padding="15,0"
                    Height="40"
                    Click="BtnRefresh_Click">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Refresh"
                                             Margin="0,0,5,0"
                                             VerticalAlignment="Center"/>
                    <TextBlock Text="Yenile" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </Grid>

        <!-- Üst Kartlar -->
        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="18"
                    Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="Personel"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="13" />
                    <TextBlock x:Name="PersonNameText"
                               Text="-"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="0,8,0,0" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="18"
                    Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="Kan Grubu"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="13" />
                    <TextBlock x:Name="BloodTypeText"
                               Text="-"
                               Foreground="{DynamicResource PrimaryBrush}"
                               FontSize="24"
                               FontWeight="Bold"
                               Margin="0,8,0,0" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="18"
                    Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="Sağlık Durumu"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="13" />
                    <TextBlock x:Name="HealthStatusText"
                               Text="-"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="0,8,0,0" />
                </StackPanel>
            </Border>

            <Border Grid.Column="3"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="18">
                <StackPanel>
                    <TextBlock Text="Son Muayene"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="13" />
                    <TextBlock x:Name="LastExamText"
                               Text="-"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               FontSize="18"
                               FontWeight="Bold"
                               Margin="0,8,0,0" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- Detay Alanı -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Kronik Hastalıklar -->
            <Border Grid.Row="0"
                    Grid.Column="0"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Margin="0,0,10,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="45" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{DynamicResource CardBrush}"
                            CornerRadius="8,8,0,0"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0">
                            <materialDesign:PackIcon Kind="MedicalBag"
                                                     Width="22"
                                                     Height="22"
                                                     Foreground="{DynamicResource PrimaryBrush}"
                                                     Margin="0,0,8,0" />
                            <TextBlock Text="Kronik Hastalıklar"
                                       FontSize="17"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                        </StackPanel>
                    </Border>

                    <ListBox Grid.Row="1"
                             x:Name="ChronicDiseasesList"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             Padding="12" />
                </Grid>
            </Border>

            <!-- Alerjiler -->
            <Border Grid.Row="0"
                    Grid.Column="1"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Margin="0,0,0,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="45" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{DynamicResource CardBrush}"
                            CornerRadius="8,8,0,0"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0">
                            <materialDesign:PackIcon Kind="Alert"
                                                     Width="22"
                                                     Height="22"
                                                     Foreground="{DynamicResource ErrorBrush}"
                                                     Margin="0,0,8,0" />
                            <TextBlock Text="Alerjiler"
                                       FontSize="17"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                        </StackPanel>
                    </Border>

                    <ListBox Grid.Row="1"
                             x:Name="AllergiesList"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             Padding="12" />
                </Grid>
            </Border>

            <!-- Çalışma Kısıtları -->
            <Border Grid.Row="1"
                    Grid.Column="0"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="45" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{DynamicResource CardBrush}"
                            CornerRadius="8,8,0,0"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,0,0,1">
                        <TextBlock Text="Çalışma Kısıtlamaları"
                                   FontSize="17"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"
                                   Margin="15,0" />
                    </Border>

                    <TextBlock Grid.Row="1"
                               x:Name="WorkRestrictionsText"
                               Text="-"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               FontSize="15"
                               Margin="15" />
                </Grid>
            </Border>

            <!-- Acil Durum Notu -->
            <Border Grid.Row="1"
                    Grid.Column="1"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="45" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{DynamicResource CardBrush}"
                            CornerRadius="8,8,0,0"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,0,0,1">
                        <TextBlock Text="Acil Durum Notu"
                                   FontSize="17"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"
                                   Margin="15,0" />
                    </Border>

                    <TextBlock Grid.Row="1"
                               x:Name="EmergencyNoteText"
                               Text="-"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               FontSize="15"
                               Margin="15" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>