<UserControl x:Class="Minemation.Desktop.MapView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:map="clr-namespace:MapControl;assembly=MapControl.WPF"
             Background="Transparent">
    
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid Margin="20">
        <!-- Harita Alanı -->
        <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="12" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="2" ClipToBounds="True">
            
            <Grid>
                <!-- Gerçek Harita Bileşeni -->
                <map:Map ZoomLevel="15" Center="41.455, 31.792" MaxZoomLevel="18" MinZoomLevel="13" Background="{DynamicResource BackgroundBrush}">
                    <Image Source="pack://application:,,,/Resources/Images/MineMap.png" Stretch="Fill" Opacity="0.9" map:MapPanel.BoundingBox="31.770, 41.440, 31.810, 41.470" />
                    
                    <!-- Girişler Katmanı -->
                    <map:MapItemsControl ItemsSource="{Binding Entrances}" Visibility="{Binding IsEntrancesVisible, Converter={StaticResource BoolToVis}}">
                        <map:MapItemsControl.ItemTemplate>
                            <DataTemplate>
                                <map:MapItem Location="{Binding Location}">
                                    <StackPanel>
                                        <materialDesign:PackIcon Kind="{Binding IconKind}" Width="48" Height="48" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                                        <Border Background="{DynamicResource CardBrush}" CornerRadius="4" Padding="5,2" Margin="0,-10,0,0">
                                            <TextBlock Text="{Binding Name}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" />
                                        </Border>
                                    </StackPanel>
                                </map:MapItem>
                            </DataTemplate>
                        </map:MapItemsControl.ItemTemplate>
                    </map:MapItemsControl>

                    <!-- Ekipman Katmanı -->
                    <map:MapItemsControl ItemsSource="{Binding Equipments}" Visibility="{Binding IsEquipmentVisible, Converter={StaticResource BoolToVis}}">
                        <map:MapItemsControl.ItemTemplate>
                            <DataTemplate>
                                <map:MapItem Location="{Binding Location}">
                                    <StackPanel>
                                        <materialDesign:PackIcon Kind="{Binding IconKind}" Width="36" Height="36" Foreground="{DynamicResource PrimaryBrush}" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding Name}" Foreground="{DynamicResource PrimaryBrush}" FontWeight="Bold" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </map:MapItem>
                            </DataTemplate>
                        </map:MapItemsControl.ItemTemplate>
                    </map:MapItemsControl>

                    <!-- Personel Katmanı -->
                    <map:MapItemsControl ItemsSource="{Binding Personnels}" Visibility="{Binding IsPersonnelVisible, Converter={StaticResource BoolToVis}}">
                        <map:MapItemsControl.ItemTemplate>
                            <DataTemplate>
                                <map:MapItem Location="{Binding Location}">
                                    <StackPanel>
                                        <materialDesign:PackIcon Kind="{Binding IconKind}" Width="28" Height="28" Foreground="{DynamicResource SuccessBrush}" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding Name}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="11" HorizontalAlignment="Center" />
                                    </StackPanel>
                                </map:MapItem>
                            </DataTemplate>
                        </map:MapItemsControl.ItemTemplate>
                    </map:MapItemsControl>
                </map:Map>

                <!-- Sağ Üst: Katman Filtreleri Paneli (Glassmorphism / Overlay) -->
                <Border HorizontalAlignment="Right" VerticalAlignment="Top" Margin="20" Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="20" 
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Opacity="0.95">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="15" Opacity="0.4" ShadowDepth="4" />
                    </Border.Effect>
                    
                    <StackPanel Width="220">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <materialDesign:PackIcon Kind="LayersOutline" Width="24" Height="24" Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Harita Katmanları" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                        
                        <Separator Background="{DynamicResource BorderBrush}" Margin="0,0,0,15" Height="1" />

                        <CheckBox Content="Personeller" IsChecked="{Binding IsPersonnelVisible}" Style="{StaticResource MaterialDesignCheckBox}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14" Margin="0,5" />
                        <CheckBox Content="Ekipmanlar" IsChecked="{Binding IsEquipmentVisible}" Style="{StaticResource MaterialDesignCheckBox}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14" Margin="0,5" />
                        <CheckBox Content="Maden Ocağı Girişleri" IsChecked="{Binding IsEntrancesVisible}" Style="{StaticResource MaterialDesignCheckBox}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14" Margin="0,5" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
