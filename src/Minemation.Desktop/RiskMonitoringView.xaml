<UserControl x:Class="Minemation.Desktop.RiskMonitoringView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="Transparent">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="RİSK İZLEME"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryBrush}" />

                <TextBlock x:Name="LastUpdatedText"
                           Text="Son güncelleme: -"
                           FontSize="13"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="0,5,0,0" />
            </StackPanel>

            <Button Grid.Column="1"
                    Style="{StaticResource MaterialDesignPaperButton}"
                    Background="{DynamicResource PrimaryBrush}"
                    Foreground="White"
                    Padding="15,0"
                    Height="40"
                    Click="BtnRefresh_Click">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Refresh"
                                             Margin="0,0,5,0"
                                             VerticalAlignment="Center"/>
                    <TextBlock Text="Yenile" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </Grid>

        <!-- Üst Alan -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Öncelikli Durumlar -->
            <Border Grid.Column="0"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Margin="0,0,10,0">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="45" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{DynamicResource CardBrush}"
                            CornerRadius="8,8,0,0"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0">
                            <materialDesign:PackIcon Kind="AlertCircle"
                                                     Width="22"
                                                     Height="22"
                                                     Foreground="{DynamicResource ErrorBrush}"
                                                     Margin="0,0,8,0" />
                            <TextBlock Text="Öncelikli Durumlar"
                                       FontSize="17"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                        </StackPanel>
                    </Border>

                    <DataGrid Grid.Row="1"
                              x:Name="PriorityGrid"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              Background="{DynamicResource SurfaceBrush}"
                              RowBackground="{DynamicResource SurfaceBrush}"
                              AlternatingRowBackground="{DynamicResource CardBrush}"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Durum" Width="90" Binding="{Binding RiskLevel}" />
                            <DataGridTextColumn Header="Sensör" Width="*" Binding="{Binding SensorTipi}" />
                            <DataGridTextColumn Header="Ekipman" Width="*" Binding="{Binding EkipmanAdi}" />
                            <DataGridTextColumn Header="Değer" Width="100" Binding="{Binding ValueText}" />
                            <DataGridTextColumn Header="Ölçüm" Width="140" Binding="{Binding OlcumText}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- CO Verileri -->
            <Border Grid.Column="1"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="45" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{DynamicResource CardBrush}"
                            CornerRadius="8,8,0,0"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0">
                            <materialDesign:PackIcon Kind="MoleculeCo"
                                                     Width="22"
                                                     Height="22"
                                                     Foreground="{DynamicResource PrimaryBrush}"
                                                     Margin="0,0,8,0" />
                            <TextBlock Text="CO Verileri"
                                       FontSize="17"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                        </StackPanel>
                    </Border>

                    <DataGrid Grid.Row="1"
                              x:Name="CoGrid"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              Background="{DynamicResource SurfaceBrush}"
                              RowBackground="{DynamicResource SurfaceBrush}"
                              AlternatingRowBackground="{DynamicResource CardBrush}"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Durum" Width="70" Binding="{Binding RiskLevel}" />
                            <DataGridTextColumn Header="Sensör" Width="*" Binding="{Binding SensorTipi}" />
                            <DataGridTextColumn Header="Konum" Width="*" Binding="{Binding EkipmanAdi}" />
                            <DataGridTextColumn Header="Değer" Width="90" Binding="{Binding ValueText}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <!-- Alt Alan -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Basınç -->
            <Border Grid.Column="0"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="45" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{DynamicResource CardBrush}"
                            CornerRadius="8,8,0,0"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,0,0,1">
                        <TextBlock Text="Basınç Verileri"
                                   FontSize="17"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"
                                   Margin="15,0" />
                    </Border>

                    <DataGrid Grid.Row="1"
                              x:Name="PressureGrid"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              HeadersVisibility="Column"
                              Background="{DynamicResource SurfaceBrush}"
                              RowBackground="{DynamicResource SurfaceBrush}"
                              AlternatingRowBackground="{DynamicResource CardBrush}"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Ekipman" Width="*" Binding="{Binding EkipmanAdi}" />
                            <DataGridTextColumn Header="Değer" Width="90" Binding="{Binding ValueText}" />
                            <DataGridTextColumn Header="Durum" Width="80" Binding="{Binding RiskLevel}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Ekipman -->
            <Border Grid.Column="1"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Margin="0,0,10,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="45" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{DynamicResource CardBrush}"
                            CornerRadius="8,8,0,0"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,0,0,1">
                        <TextBlock Text="Ekipman Verileri"
                                   FontSize="17"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"
                                   Margin="15,0" />
                    </Border>

                    <DataGrid Grid.Row="1"
                              x:Name="EquipmentGrid"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              HeadersVisibility="Column"
                              Background="{DynamicResource SurfaceBrush}"
                              RowBackground="{DynamicResource SurfaceBrush}"
                              AlternatingRowBackground="{DynamicResource CardBrush}"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Ekipman" Width="*" Binding="{Binding EkipmanAdi}" />
                            <DataGridTextColumn Header="Sensör" Width="*" Binding="{Binding SensorTipi}" />
                            <DataGridTextColumn Header="Değer" Width="90" Binding="{Binding ValueText}" />
                            <DataGridTextColumn Header="Durum" Width="80" Binding="{Binding RiskLevel}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Sıcaklık -->
            <Border Grid.Column="2"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="45" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{DynamicResource CardBrush}"
                            CornerRadius="8,8,0,0"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,0,0,1">
                        <TextBlock Text="Sıcaklık Verileri"
                                   FontSize="17"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"
                                   Margin="15,0" />
                    </Border>

                    <DataGrid Grid.Row="1"
                              x:Name="TemperatureGrid"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              HeadersVisibility="Column"
                              Background="{DynamicResource SurfaceBrush}"
                              RowBackground="{DynamicResource SurfaceBrush}"
                              AlternatingRowBackground="{DynamicResource CardBrush}"
                              Foreground="{DynamicResource TextPrimaryBrush}"
                              BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Ekipman" Width="*" Binding="{Binding EkipmanAdi}" />
                            <DataGridTextColumn Header="Değer" Width="90" Binding="{Binding ValueText}" />
                            <DataGridTextColumn Header="Durum" Width="80" Binding="{Binding RiskLevel}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>