<UserControl x:Class="Minemation.Desktop.RiskMonitoringView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="Transparent">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="1.5*" /> <!-- Top Section -->
            <RowDefinition Height="1*" />   <!-- Bottom Section -->
        </Grid.RowDefinitions>

        <!-- Top Section -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>
            
            <!-- Öncelikli Durumlar -->
            <Border Grid.Column="0" Background="{DynamicResource CardBrush}" CornerRadius="8" Margin="0,0,20,0" Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0">
                        <TextBlock Text="Öncelikli Durumlar" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="20" FontWeight="SemiBold"/>
                        <Separator Background="{DynamicResource BorderBrush}" Margin="0,10,0,10" Height="2"/>
                    </StackPanel>
                    
                    <!-- Content Placeholder -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <TextBlock Text="Henüz öncelikli bir durum bulunmuyor." Foreground="{DynamicResource TextSecondaryBrush}" Opacity="0.5" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,50,0,0" />
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- CO Verileri -->
            <Border Grid.Column="1" Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0">
                        <TextBlock Text="CO Verileri" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="20" FontWeight="SemiBold"/>
                        <Separator Background="{DynamicResource BorderBrush}" Margin="0,10,0,10" Height="2"/>
                    </StackPanel>
                    
                    <DataGrid Grid.Row="1" x:Name="CoDataGrid" AutoGenerateColumns="False" CanUserAddRows="False" 
                              Background="Transparent" RowBackground="Transparent" 
                              Foreground="{DynamicResource TextPrimaryBrush}" 
                              HeadersVisibility="Column" GridLinesVisibility="All" 
                              HorizontalGridLinesBrush="{DynamicResource BorderBrush}" 
                              VerticalGridLinesBrush="{DynamicResource BorderBrush}"
                              BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" RowHeight="40">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                                <Setter Property="FontSize" Value="14" />
                                <Setter Property="Padding" Value="5" />
                                <Setter Property="BorderThickness" Value="0,0,1,1" />
                                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell" BasedOn="{StaticResource MaterialDesignDataGridCell}">
                                <Setter Property="BorderThickness" Value="0,0,1,1" />
                                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
                                <Setter Property="Padding" Value="5" />
                            </Style>
                        </DataGrid.CellStyle>
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Durum" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <materialDesign:PackIcon Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <materialDesign:PackIcon.Style>
                                                <Style TargetType="materialDesign:PackIcon">
                                                    <Setter Property="Kind" Value="TriangleOutline" />
                                                    <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Down">
                                                            <Setter Property="Kind" Value="TriangleDownOutline" />
                                                            <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </materialDesign:PackIcon.Style>
                                        </materialDesign:PackIcon>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Sensör" Binding="{Binding SensorName}" Width="*" />
                            <DataGridTextColumn Header="Konum" Binding="{Binding Location}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <!-- Bottom Section -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            
            <!-- Basınç Verileri -->
            <Border Grid.Column="0" Background="{DynamicResource CardBrush}" CornerRadius="8" Margin="0,0,10,0" Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0">
                        <TextBlock Text="Basınç Verileri" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="20" FontWeight="SemiBold"/>
                        <Separator Background="{DynamicResource BorderBrush}" Margin="0,10,0,10" Height="2"/>
                    </StackPanel>
                    
                    <TextBlock Grid.Row="1" Text="Güncel veri bekleniyor..." Foreground="{DynamicResource TextSecondaryBrush}" Opacity="0.5" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,30,0,0"/>
                </Grid>
            </Border>

            <!-- Ekipman Verileri -->
            <Border Grid.Column="1" Background="{DynamicResource CardBrush}" CornerRadius="8" Margin="10,0,10,0" Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0">
                        <TextBlock Text="Ekipman Verileri" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="20" FontWeight="SemiBold"/>
                        <Separator Background="{DynamicResource BorderBrush}" Margin="0,10,0,10" Height="2"/>
                    </StackPanel>
                    
                    <TextBlock Grid.Row="1" Text="Güncel veri bekleniyor..." Foreground="{DynamicResource TextSecondaryBrush}" Opacity="0.5" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,30,0,0"/>
                </Grid>
            </Border>

            <!-- Sıcaklık Verileri -->
            <Border Grid.Column="2" Background="{DynamicResource CardBrush}" CornerRadius="8" Margin="10,0,0,0" Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0">
                        <TextBlock Text="Sıcaklık Verileri" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="20" FontWeight="SemiBold"/>
                        <Separator Background="{DynamicResource BorderBrush}" Margin="0,10,0,10" Height="2"/>
                    </StackPanel>
                    
                    <TextBlock Grid.Row="1" Text="Güncel veri bekleniyor..." Foreground="{DynamicResource TextSecondaryBrush}" Opacity="0.5" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,30,0,0"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
