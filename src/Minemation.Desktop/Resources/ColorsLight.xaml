<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Base Colors (Light Earth) -->
    <Color x:Key="ColorBackground">#FDFBF7</Color>
    <Color x:Key="ColorSurface">#F5EBE1</Color>
    <Color x:Key="ColorCard">#FFFFFF</Color>
    <Color x:Key="ColorBorder">#E0D8C8</Color>

    <!-- Main Colors (Dark Brown Accents) -->
    <Color x:Key="ColorPrimary">#3E2723</Color>
    <Color x:Key="ColorPrimaryHover">#4E342E</Color>
    <Color x:Key="ColorSecondary">#5D4037</Color>
    <Color x:Key="ColorSecondaryHover">#4E342E</Color>

    <!-- Text Colors (Dark Brown) -->
    <Color x:Key="ColorTextPrimary">#2A1E1A</Color>
    <Color x:Key="ColorTextSecondary">#4E342E</Color>

    <!-- Status Colors -->
    <Color x:Key="ColorError">#D32F2F</Color>
    <Color x:Key="ColorWarning">#F57C00</Color>
    <Color x:Key="ColorSuccess">#388E3C</Color>
    <Color x:Key="ColorInfo">#1976D2</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource ColorBackground}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource ColorSurface}" />
    <SolidColorBrush x:Key="CardBrush" Color="{StaticResource ColorCard}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource ColorBorder}" />

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource ColorPrimary}" />
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="{StaticResource ColorPrimaryHover}" />
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource ColorSecondary}" />
    <SolidColorBrush x:Key="SecondaryHoverBrush" Color="{StaticResource ColorSecondaryHover}" />

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource ColorTextPrimary}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource ColorTextSecondary}" />

    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ColorError}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource ColorWarning}" />
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource ColorSuccess}" />
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource ColorInfo}" />

    <!-- Additional styling for Glassmorphism/Overlay -->
    <SolidColorBrush x:Key="GlassBrush" Color="#B3FDFBF7" />
</ResourceDictionary>
